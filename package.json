{
	"name": "dispatchly",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"elysia": "^1.4.21",
			"@trpc/server": "^11.13.4",
			"better-auth": "1.5.5",
			"@better-auth/stripe": "^1.4.20",
			"stripe": "^22.0.0",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@trpc/client": "^11.13.4",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:admin": "turbo -F admin dev",
		"dev:client": "turbo -F client dev",
		"dev:server": "turbo -F server dev",
		"db:start": "turbo -F @dispatchly/db db:start",
		"db:watch": "turbo -F @dispatchly/db db:watch",
		"db:stop": "turbo -F @dispatchly/db db:stop",
		"db:down": "turbo -F @dispatchly/db db:down",
		"test:infra:start": "docker compose -f docker-compose.test.yml up -d",
		"test:infra:stop": "docker compose -f docker-compose.test.yml down",
		"check": "biome check --write .",
		"test": "turbo test",
		"test:e2e": "cd apps/e2e && npx playwright test",
		"prepare": "husky"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.0",
		"@better-auth/stripe": "^1.6.5",
		"@dispatchly/env": "workspace:*",
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/trpc": "^1.1.0",
		"@hono/trpc-server": "^0.4.2",
		"@t3-oss/env-core": "^0.13.11",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tailwindcss/postcss": "^4.2.2",
		"@tanstack/react-form": "^1.29.0",
		"@tanstack/react-query": "^5.99.0",
		"@tanstack/react-query-devtools": "^5.99.0",
		"@tauri-apps/cli": "^2.10.1",
		"@trpc/client": "^11.16.0",
		"@trpc/server": "^11.16.0",
		"@trpc/tanstack-react-query": "^11.16.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"better-auth": "^1.6.5",
		"bullmq": "^5.74.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"elysia": "^1.4.28",
		"expo-server-sdk": "^6.1.0",
		"ioredis": "^5.10.1",
		"lucide-react": "^1.8.0",
		"mongoose": "^9.4.1",
		"next-themes": "^0.4.6",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"resend": "^6.12.0",
		"shadcn": "^4.3.0",
		"sonner": "^2.0.7",
		"stripe": "^22.0.2",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"tsdown": "^0.21.9",
		"tw-animate-css": "^1.4.0",
		"twilio": "^5.13.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@dispatchly/config": "workspace:*",
		"@types/bun": "^1.3.12",
		"husky": "^9.1.7",
		"lefthook": "^2.1.6",
		"lint-staged": "^16.4.0",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write"
		]
	},
	"packageManager": "bun@1.3.12"
}
