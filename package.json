{
	"name": "dispatchly",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"react": "^19.2.5",
			"react-dom": "^19.2.5",
			"@types/react": "^19.2.14",
			"@types/react-dom": "^19.2.3",
			"zod": "4.3.6",
			"better-auth": "^1.6.9",
			"@better-auth/api-key": "^1.6.9",
			"@better-auth/stripe": "^1.6.9",
			"stripe": "^22.1.0",
			"lucide-react": "^1.11.0",
			"next-themes": "^0.4.6",
			"sonner": "^2.0.7",
			"tailwindcss": "^4.2.4",
			"typescript": "^6.0.3",
			"@types/bun": "^1.3.13",
			"dotenv": "^17.4.2",
			"@trpc/client": "^11.16.0",
			"@trpc/server": "^11.16.0",
			"@trpc/tanstack-react-query": "^11.16.0",
			"@tanstack/react-query": "^5.100.4",
			"elysia": "^1.4.28",
			"mongoose": "^9.5.0",
			"mongodb": "^7.1.1",
			"class-variance-authority": "^0.7.1",
			"clsx": "^2.1.1",
			"tailwind-merge": "^3.5.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:admin": "turbo -F admin dev",
		"dev:client": "turbo -F client dev",
		"dev:server": "turbo -F server dev",
		"db:start": "turbo -F @dispatchly/db db:start",
		"db:watch": "turbo -F @dispatchly/db db:watch",
		"db:stop": "turbo -F @dispatchly/db db:stop",
		"db:down": "turbo -F @dispatchly/db db:down",
		"test:infra:start": "docker compose -f docker-compose.test.yml up -d",
		"test:infra:stop": "docker compose -f docker-compose.test.yml down",
		"check": "biome check --write .",
		"test": "turbo test",
		"test:e2e": "cd apps/e2e && npx playwright test",
		"prepare": "husky"
	},
	"dependencies": {
		"@dispatchly/env": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@dispatchly/config": "workspace:*",
		"husky": "^9.1.7",
		"lefthook": "^2.1.6",
		"lint-staged": "^16.4.0",
		"turbo": "^2.9.6"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write"
		]
	},
	"packageManager": "bun@1.3.12"
}
