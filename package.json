{
	"name": "dispatchly",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"elysia": "^1.4.21",
			"@trpc/server": "^11.13.4",
			"better-auth": "1.5.5",
			"@better-auth/stripe": "^1.4.20",
			"stripe": "^22.0.0",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@trpc/client": "^11.13.4",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:start": "turbo -F @dispatchly/db db:start",
		"db:watch": "turbo -F @dispatchly/db db:watch",
		"db:stop": "turbo -F @dispatchly/db db:stop",
		"db:down": "turbo -F @dispatchly/db db:down",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@better-auth/stripe": "^1.6.5",
		"@dispatchly/env": "workspace:*",
		"bullmq": "^5.74.1",
		"dotenv": "catalog:",
		"expo-server-sdk": "^6.1.0",
		"ioredis": "^5.10.1",
		"resend": "^6.12.0",
		"stripe": "^22.0.2",
		"twilio": "^5.13.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@dispatchly/config": "workspace:*",
		"@types/bun": "catalog:",
		"husky": "^9.1.7",
		"lefthook": "^2.0.13",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.12"
}
