{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@dispatchly/api": "workspace:*",
		"@dispatchly/auth": "workspace:*",
		"@dispatchly/db": "workspace:*",
		"@dispatchly/env": "workspace:*",
		"@elysiajs/cors": "^1.4.2",
		"@elysiajs/trpc": "^1.1.0",
		"@hono/trpc-server": "^0.4.2",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"elysia": "catalog:",
		"elysia-rate-limit": "^4.6.0",
		"bullmq": "^5.76.2",
		"ioredis": "^5.10.1",
		"tsdown": "^0.21.10",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@dispatchly/config": "workspace:*",
		"@types/bun": "catalog:",
		"typescript": "catalog:"
	}
}
